# ============================================================
# TRADING BOT CONFIGURATION
# Copy this file to .env and fill in your values.
# On Raspberry Pi: only change PATH and machine-specific creds.
# ============================================================

# Absolute path to the project root folder.
# Windows:      PATH=C:/Users/louis/OneDrive/Louis/trading_strategy
# Raspberry Pi: PATH=/home/pi/trading_strategy
PATH=C:/Users/louis/OneDrive/Louis/trading_strategy

# ---- Telegram Listener ----
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=telegram_session
TELEGRAM_PHONE=
TELEGRAM_GROUP_NAME=Wallstreet Queen Official VIP

# ---- Bybit ----
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# ---- Risk / Position Sizing ----
DEFAULT_LEVERAGE=10
MAX_LEVERAGE=10
RISK_PER_TRADE=0.03
DRY_RUN=false

# ---- Alert Bot ----
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=

# ---- Derived paths ----
BOT_LOG_FILE=${PATH}/logs/bot.log
DB_PATH=${PATH}/data/bot.db
SESSION_DIR=${PATH}/sessions

# ---- Alert thresholds (seconds) ----
ALERT_TELEGRAM_SECONDS=120
ALERT_BYBIT_SECONDS=180
ALERT_SL_SECONDS=90
ALERT_TP_SECONDS=120
ALERT_COOLDOWN_SECONDS=600
